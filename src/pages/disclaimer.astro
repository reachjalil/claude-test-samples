---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Disclaimer"
  description="Independence, trademark, exam-content, and educational-use disclaimer for Sample Claude Exams."
>
  <section class="exam-page legal-page">
    <header class="page-intro">
      <span class="exam-page-eyebrow">Legal</span>
      <h1 class="exam-page-title">Disclaimer</h1>
      <p class="section-lede">Last updated July 2, 2026.</p>
    </header>

    <div class="legal-stack">
      <section>
        <h2>Independent educational site</h2>
        <p>
          Sample Claude Exams is an independent practice website. It is not affiliated with,
          endorsed by, sponsored by, or operated by Anthropic. It does not represent Anthropic and
          does not provide official certification, official exam access, or official exam results.
        </p>
      </section>

      <section>
        <h2>Trademark reference</h2>
        <p>
          Claude and Anthropic are referenced only to identify the subject of the educational
          practice material. Any trademarks, product names, or company names belong to their
          respective owners.
        </p>
      </section>

      <section>
        <h2>Exam-content boundary</h2>
        <p>
          The questions on this site are sample practice material. They should not be treated as
          live exam questions, leaked exam content, official answer keys, or a guarantee of passing
          any certification or assessment.
        </p>
      </section>

      <section>
        <h2>Learning-use boundary</h2>
        <p>
          Scores are intended for study planning and readiness conversations. They are not hiring,
          compliance, licensing, or professional qualification determinations.
        </p>
      </section>
    </div>
  </section>
</SiteLayout>
